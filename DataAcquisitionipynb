        "        lambda href: 'cnnindonesia.com' in href and '/' in href[30:],\n",
        "        'cnn_search'\n",
        "    ),\n",
        "}\n",
        "\n",
        "tasks = [\n",
        "    (kw, name, url_fn, domain_fn, method)\n",
        "    for name, (url_fn, domain_fn, method) in SCRAPERS.items()\n",
        "    for kw in KEYWORDS\n",
        "]\n",
        "\n",
        "all_web = []\n",
        "with ThreadPoolExecutor(max_workers=4) as executor:\n",
        "    futures = {executor.submit(fetch_site, t): t for t in tasks}\n",
