        "### 4a. Google News RSS\n",
        "Scraping via RSS feed Google News per keyword dengan time range 180d dan 365d."
      ],
      "metadata": {
        "id": "HZ_CBVllvNPn"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
        "\n",
        "def scrape_google_news(keyword, time_range='90d', max_results=100):\n",
        "    articles = []\n",
        "    url = f'https://news.google.com/rss/search?q={quote_plus(keyword)}+when:{time_range}&hl=id&gl=ID&ceid=ID:id'\n",
        "    feed = feedparser.parse(url)\n",
        "    for entry in feed.entries[:max_results]:\n",
        "        try:\n",
        "            try:\n",
        "                pub = datetime(*entry.published_parsed[:6]).strftime('%Y-%m-%d %H:%M:%S')\n",
        "            except Exception:\n",
        "                pub = entry.get('published', '')\n",
        "            articles.append({\n",
        "                'judul': clean_text(entry.get('title', '')),\n",
        "                'url': entry.get('link', ''),\n",
        "                'sumber': entry.get('source', {}).get('title', 'Unknown'),\n",
        "                'tanggal': pub,\n",
        "                'ringkasan': clean_text(entry.get('summary', '')),\n",
        "                'keyword': keyword,\n",
        "                'metode_scraping': f'google_news_{time_range}'\n",
        "            })\n",
        "        except Exception:\n",
        "            continue\n",
        "    return articles\n",
        "\n",
        "def fetch_google(args):\n",
        "    kw, tr = args\n",
        "    time.sleep(random.uniform(0.5, 1.5))\n",
        "    return scrape_google_news(kw, tr, max_results=100)\n",
        "\n",
        "BUFFER_TARGET = TARGET_ARTICLES * 2\n",
        "tasks = [(kw, tr) for tr in ['180d', '365d'] for kw in KEYWORDS]\n",
        "all_google = []\n",
        "\n",
        "with ThreadPoolExecutor(max_workers=5) as executor:\n",
        "    futures = {executor.submit(fetch_google, t): t for t in tasks}\n",
        "    with tqdm(total=len(tasks), desc='Google News') as pbar:\n",
        "        for future in as_completed(futures):\n",
        "            all_google.extend(future.result())\n",
        "            pbar.update(1)\n",
        "            if len(all_google) >= BUFFER_TARGET:\n",
        "                pbar.n = pbar.total\n",
        "                pbar.refresh()\n",
        "                executor.shutdown(wait=False, cancel_futures=True)\n",
        "                break\n",
        "\n",
        "print(f'Google News (before dedup): {len(all_google)}')"
      ],
