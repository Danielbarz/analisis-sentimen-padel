      "cell_type": "code",
      "source": [
        "def get_sentiment_textblob(text):\n",
        "    if not text or len(text) < 5:\n",
        "        return 0.0, 0.0, 'netral'\n",
        "    analysis = TextBlob(str(text))\n",
        "    polarity = analysis.sentiment.polarity\n",
        "    subjectivity = analysis.sentiment.subjectivity\n",
        "    if polarity > 0.05:\n",
        "        label = 'positif'\n",
        "    elif polarity < -0.05:\n",
        "        label = 'negatif'\n",
        "    else:\n",
        "        label = 'netral'\n",
        "    return polarity, subjectivity, label\n",
        "\n",
        "df[['polarity', 'subjectivity', 'sentimen']] = df['teks_analisis'].apply(\n",
        "    lambda x: pd.Series(get_sentiment_textblob(x))\n",
        ")\n",
        "\n",
        "# Mapping ke angka sesuai pipeline (0=Neg, 1=Netral, 2=Pos)\n",
        "label_map = {'negatif': 0, 'netral': 1, 'positif': 2}\n",
        "df['label'] = df['sentimen'].map(label_map)\n",
        "\n",
        "print('Sentiment analysis done.')\n",
        "print(df['sentimen'].value_counts().to_string())"
