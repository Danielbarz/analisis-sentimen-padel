        "# Keyword yang harus ada minimal 1 di judul/konten agar dianggap relevan\n",
        "RELEVANCE_KEYWORDS = [\n",
        "    'padel', 'padel sport', 'lapangan padel', 'raket padel',\n",
        "    'turnamen padel', 'padel court', 'padel indonesia',\n",
        "    'komunitas padel', 'klub padel', 'padel center',\n",
        "    'world padel', 'padel pro', 'padel event'\n",
        "]\n",
        "\n",
        "def is_relevant(row):\n",
        "    combined = (str(row.get('judul', '')) + ' ' + str(row.get('konten', ''))).lower()\n",
        "    return any(kw in combined for kw in RELEVANCE_KEYWORDS)\n",
        "\n",
        "before = len(df)\n",
        "df = df[df.apply(is_relevant, axis=1)].reset_index(drop=True)\n",
        "print(f'Filtered: {before} -> {len(df)} ({before - len(df)} removed)')\n",
        "\n",
        "def preprocess(text):\n",
        "    if not text:\n",
        "        return ''\n",
        "    text = re.sub(r'<[^>]+>', '', str(text))       # hapus HTML tags\n",
        "    text = re.sub(r'http\\S+|www\\.\\S+', '', text)    # hapus URL\n",
        "    text = re.sub(r'\\s+', ' ', text)                # normalize whitespace\n",
        "    text = text.lower().strip()\n",
        "    text = re.sub(r'[^a-z0-9\\s]', '', text)         # hapus non-alfanumerik\n",
        "    return text\n",
