        "def scrape_site(keyword, base_url_fn, domain_check, source_name, method_name, max_pages=5):\n",
        "    articles = []\n",
        "    for page in range(1, max_pages + 1):\n",
        "        url = base_url_fn(keyword, page)\n",
        "        r = safe_request(url)\n",
        "        if not r:\n",
        "            break\n",
        "        soup = BeautifulSoup(r.text, 'lxml')\n",
        "        found = False\n",
        "        for a in soup.find_all('a', href=True):\n",
        "            href = a.get('href', '')\n",
        "            title = clean_text(a.get_text())\n",
        "            if title and len(title) > 15 and domain_check(href):\n",
        "                if not href.startswith('http'):\n",
        "                    href = urljoin(f'https://{source_name.lower()}.com', href)\n",
        "                articles.append({\n",
        "                    'judul': title, 'url': href,\n",
        "                    'sumber': source_name, 'tanggal': '',\n",
        "                    'ringkasan': '', 'keyword': keyword,\n",
        "                    'metode_scraping': method_name\n",
        "                })\n",
        "                found = True\n",
        "        if not found:\n",
        "            break\n",
        "        time.sleep(random.uniform(0.5, 1.0))  # delay hanya per page, bukan per keyword\n",
        "    return articles\n",
        "\n",
        "def fetch_site(args):\n",
        "    kw, site_name, url_fn, domain_fn, method = args\n",
        "    time.sleep(random.uniform(0.3, 0.8))\n",
        "    return scrape_site(kw, url_fn, domain_fn, site_name, method, max_pages=5)\n",
        "\n",
        "SCRAPERS = {\n",
        "    'Detik.com': (\n",
        "        lambda kw, p: f'https://www.detik.com/search/searchall?query={quote_plus(kw)}&page={p}&sortby=time',\n",
        "        lambda href: 'detik.com' in href and ('/d-' in href or '/berita/' in href),\n",
        "        'detik_search'\n",
        "    ),\n",
        "    'Kompas.com': (\n",
        "        lambda kw, p: f'https://search.kompas.com/search/?q={quote_plus(kw)}&page={p}',\n",
        "        lambda href: 'kompas.com' in href and '/read/' in href,\n",
        "        'kompas_search'\n",
